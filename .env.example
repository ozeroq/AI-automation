# ===== AI APIs =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx  # 선택, 백업용

# Claude 모델 선택
ANTHROPIC_MODEL=claude-opus-4-7

# ===== 어필리에이트 / 수익화 =====
# 쿠팡파트너스: https://partners.coupang.com 가입 (무료)
COUPANG_PARTNERS_ID=your_partner_id
# Google AdSense 승인 후
ADSENSE_CLIENT_ID=

# ===== 블로그 발행 =====
# GitHub Pages 사용 시 자동 (별도 설정 불필요)
BLOG_BASE_URL=https://YOUR_USERNAME.github.io/AI-automation
BLOG_AUTHOR=익명
BLOG_TIMEZONE=Asia/Seoul

# ===== SaaS 결제 =====
# Stripe: https://stripe.com (테스트 모드는 무료)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Toss Payments (한국 결제, 사업자등록 후)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ===== Rate Limiting =====
# Upstash Redis 무료 티어 (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== 운영 =====
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
