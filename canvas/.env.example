# ===== 결제 =====
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# Pro 구독 Price ID (Stripe Dashboard에서 생성, 없으면 ₩15,000/월 인라인 가격 사용)
STRIPE_PRO_PRICE_ID=

# Toss Payments (한국, 사업자등록 후)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ===== 스토리지 =====
# Upstash Redis 무료 티어 (블록 메타데이터)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (이미지 업로드)
BLOB_READ_WRITE_TOKEN=

# ===== 인증 =====
# 매직 링크·세션 JWT 서명용. 32자 이상 권장: openssl rand -base64 48
AUTH_SECRET=

# ===== 이메일 (Resend) =====
# 미설정 시 dev 모드에서 로그인 링크를 응답에 직접 반환 (production 에서는 필수)
RESEND_API_KEY=
RESEND_FROM=PixelRoom <noreply@yourdomain.com>

# ===== 관리자 (미사용) =====
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SECRET=change_me

# ===== 도메인 =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=PixelRoom
